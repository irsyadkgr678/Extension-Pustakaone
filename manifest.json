{
  "manifest_version": 3,
  "name": "PustakaONE",
  "description": "Akses jurnal IEEE, Scopus, dan publisher lainnya melalui jaringan kampus Telkom University",
  "version": "1.1.1",
  "permissions": [
    "proxy",
    "storage",
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PustakaONE Proxy"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}